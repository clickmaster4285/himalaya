generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  BOOKING_MANAGER
  USER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id           String    @id @default(cuid()) @map("_id")
  fullName     String
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]
}

model Booking {
  id             String        @id @default(cuid()) @map("_id")
  reference      String        @unique
  experienceType String
  packageName    String
  bookingDate    DateTime
  totalAmount    Int
  status         BookingStatus @default(PENDING)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Villa {
  id          String   @id @default(cuid()) @map("_id")
  slug        String   @unique
  title       String
  category    String
  description String
  price       String
  image       String
  gallery     String[]
  bedrooms    Int
  guests      Int
  size        String
  highlights  String[]
  amenities   String[]
  content     String
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([category])
}
